# Template for the project's .env file. Copy to .env and fill in real values.
#
#   cp .env.example .env
#   $EDITOR .env
#
# The real .env is gitignored. This template is committed so anyone cloning
# the repo knows which variables to set. See README.md "Cloudflare R2 setup"
# for where each value comes from.

# S3-compatible endpoint for boto3. Pattern:
#   https://<account-id>.r2.cloudflarestorage.com
BUCKET_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# R2 API token credentials (R2 → Manage R2 API Tokens → Create).
# Scope: Object Read & Write, restricted to the bucket below.
BUCKET_ACCESS_KEY_ID=<access-key-id>
BUCKET_SECRET_ACCESS_KEY=<secret-access-key>

# R2 uses 'auto' as the region for the standard endpoint.
BUCKET_REGION=auto

# The bucket name you picked when creating it in the R2 dashboard.
BUCKET_NAME=aot-stimuli

# Public read URL — the r2.dev managed subdomain shown under
# Bucket → Settings → Public access. Used as --base-url for
# build_manifest.py when generating the production manifest.
PUBLIC_BASE_URL=https://pub-<32-char-hash>.r2.dev
