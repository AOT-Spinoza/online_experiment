# Secrets / private data — never commit
.env
.env.*
!.env.example
secrets/
**/manifest_private.json
**/hash_map.tsv

# Pipeline data — large, user-managed
videos/
pipeline/source/
pipeline/source_obvious/
pipeline/staging/
pipeline/staging_hashed/
pipeline/staging_hashed.zip
pipeline/staging_hashed.tar*

# Cloudflare Wrangler CLI local state
pipeline/.wrangler/
.wrangler/

# JATOS deployment bundle — rebuilt from experiment/dist on each deploy
aot-experiment.zip
*.zip

# Per-participant exports / saved CSVs — analyst working data, never commit
analysis/data/
analysis/*.executed.ipynb

# Derived analysis outputs: regenerated from analysis/data/ + the private
# manifest by `python -m analysis.load_all` etc. Contains PIDs and
# per-subject diagnostic plots, so we do NOT commit them.
analysis/derived/

# Local-dev build artifacts that are regenerated by `python pipeline/dev_link.py`
# (the symlink is a relative path into pipeline/staging_hashed/; stimuli.json
# is a copy of pipeline/manifest_public.json rewritten with relative URLs).
experiment/public/_videos
experiment/public/stimuli.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Node / JS build artifacts
experiment/node_modules/
experiment/dist/
experiment/.cache/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
